# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.playwright-cli/

# generated/downloaded images (large, not source)
/generated-images/
/printify-mockups/

# printify artwork intermediate files (keep src/ SVGs and output/ finals)
/printify-artwork/*.png
/printify-artwork/*.psd
/printify-artwork/*.svg

# agent/skill artifacts
.agent/
.agents/
.claude/skills/
/skills/
skills-lock.json
